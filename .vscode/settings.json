{
    "chat.allowAnonymousAccess": false,
    "chat.useHooks": false,
    "chat.useClaudeMdFile": false,
    "chat.useAgentsMdFile": false,
    "chat.promptFilesLocations": {
        ".github/prompts": false
    },
    "chat.instructionsFilesLocations": {
        ".github/instructions": false,
